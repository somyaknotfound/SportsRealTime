# =========================
# Database (MySQL)
# =========================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=sportrealtime

# =========================
# Server
# =========================
PORT=8000
HOST=0.0.0.0

# =========================
# JWT Authentication
# =========================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-before-production
JWT_EXPIRES_IN=7d

# =========================
# Arcjet Security
# =========================
ARCJET_KEY=ajkey_your_key_here
ARCJET_ENV=development
# Set to DRY_RUN to log without blocking
# ARCJET_MODE=DRY_RUN

# =========================
# APM (optional)
# =========================
APM_LICENSE_KEY=your_apm_key_here
APM_APP_NAME=SportRealTime
APM_PORT=10000

# =========================
# API URL
# =========================
API_URL=http://localhost:8000

# =========================
# Seeding / Broadcasting
# =========================
BROADCAST=1
DELAY_MS=250
MATCH_COUNT=0
